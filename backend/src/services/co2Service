// src/services/co2Service.js
const axios = require('axios');

// Fattori di emissione medi (in grammi di CO2 per km)
const EMISSION_FACTORS = {
	bus: 104, // Media per passeggero sui mezzi pubblici
	car_average: 110 // Media italiana per auto generica
};

/**
 * Funzione che recupera i grammi di CO2 per km di una specifica auto cercando online la targa
 */
async function getCarEmissionFactor(plate) {
	// Se l'utente non ha salvato la targa, usiamo la media nazionale
	if (!plate) {
		return EMISSION_FACTORS.car_average;
	}

	try {
		// ==========================================
		// CHIAMATA API ESTERNA PER LA TARGA
		// Sostituisci questo URL con l'API di un database targhe reale (es. ACI o Infotarga)
		// ==========================================
		/*
        const response = await axios.get(`https://api.serviziotarghe.it/veicolo/${plate}`, {
            headers: { 'Authorization': `Bearer ${process.env.TARGA_API_KEY}` }
        });
        return response.data.co2_emissions; // Restituisce es. 120 g/km
        */

		// Per il momento (e per i nostri test), simuliamo il comportamento di un'API online
		console.log(`Ricerca dati online per la targa: ${plate}...`);

		// Simuliamo l'intelligenza dell'API online:
		if (plate.toUpperCase().startsWith('E')) {
			return 0; // Fingiamo che le targhe che iniziano con E siano auto elettriche!
		}
		if (plate.toUpperCase().startsWith('A')) {
			return 140; // Fingiamo che siano auto vecchie e inquinanti
		}

		// Auto standard trovata nel database online
		return 120;
	} catch (error) {
		console.error(
			'Errore durante il recupero dei dati online per la targa:',
			error.message
		);
		// Fallback: se l'API online è giù o non trova la targa, usiamo la media nazionale
		return EMISSION_FACTORS.car_average;
	}
}

/**
 * Calcola le emissioni per tutti i mezzi, date le loro distanze in km
 */
async function calculateEmissions(distances, userPlate) {
	// Scopriamo quanto inquina l'auto specifica dell'utente
	const carEmissionFactor = await getCarEmissionFactor(userPlate);

	// Effettuiamo i calcoli (Distanza * Fattore di Emissione)
	return {
		walking: 0,
		bicycling: 0,
		// Moltiplichiamo i km per i grammi di CO2. Se la distanza non c'è, restituiamo null.
		transit: distances.transit
			? distances.transit * EMISSION_FACTORS.bus
			: null,
		driving: distances.driving
			? distances.driving * carEmissionFactor
			: null,

		// Informazione utile da mostrare nell'app
		note: userPlate
			? `Calcolo auto basato sui dati reali della targa ${userPlate}`
			: 'Calcolo auto basato sulla media nazionale (nessuna targa fornita)'
	};
}

module.exports = { calculateEmissions };
